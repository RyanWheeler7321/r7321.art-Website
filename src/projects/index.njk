---
layout: layouts/base.njk
pageClass: page-projects
title: Projects
description: Projects
---
<section class="shell page-title-block">
  <h1>Projects</h1>
</section>

<section class="shell project-card-grid">
  {% for project in collections.projects %}
    <article class="project-card">
      <a class="project-card-media" href="{{ project.url }}">
        {% managedLoop project.data.thumbnail, project.data.title, "project-card-managed" %}
      </a>
      <div class="project-card-copy">
        <div class="project-card-head">
          <h2><a href="{{ project.url }}">{{ project.data.title }}</a></h2>
        </div>
        <div class="meta-row project-card-tag-row">
          {% for tag in project.data.tags | displayTags %}
            <span class="tag-chip">{{ tag }}</span>
          {% endfor %}
        </div>
        <div class="project-card-subhead">
          <span class="project-card-date">{{ project.data.dateLabel }}</span>
        </div>
        <p>{{ project.data.summary }}</p>
      </div>
    </article>
  {% endfor %}
</section>
