---
layout: layouts/base.njk
pageClass: page-tool-detail
---
{% set primaryAction = download or primaryAction or (externalLinks and externalLinks[0]) %}
{% set showcaseItems = showcaseImages or [] %}

<section class="shell tool-detail-header">
  <div class="tool-detail-header-copy">
    {% if thumbnail %}
      <div class="tool-detail-icon-frame" aria-hidden="true">
        <img src="{{ thumbnail | optimizedImage }}" alt="">
      </div>
    {% endif %}

    <div class="tool-detail-header-main">
      <h1>{{ title }}</h1>
      {% if summary %}
        <p class="detail-summary">{{ summary }}</p>
      {% endif %}
      <div class="tag-row tool-detail-tag-row">
        {% for tag in tags | displayTags %}
          <span class="tag-chip">{{ tag }}</span>
        {% endfor %}
      </div>

      {% if primaryAction %}
        <a
          class="button button-primary tool-primary-button"
          href="{{ primaryAction.url }}"
          {% if not primaryAction.download %}target="_blank" rel="noopener"{% endif %}
        >
          {% if primaryAction.download %}
            <i class="fa-solid fa-download" aria-hidden="true"></i>
          {% else %}
            <i class="fa-brands fa-github" aria-hidden="true"></i>
          {% endif %}
          <span>{{ primaryAction.label }}</span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

<section class="shell tool-detail-body {% if showcaseItems.length %}tool-detail-body-showcase{% else %}tool-detail-body-plain{% endif %}">
  <article class="detail-article tool-detail-article">
    <div class="detail-prose">
      {{ content | safe }}
    </div>
  </article>

  {% if showcaseItems.length %}
    <aside class="tool-detail-showcase">
      {% for image in showcaseItems %}
        <figure class="media-frame tool-showcase-frame">
          {% managedImage image.src or image, image.alt or title, "tool-showcase-managed" %}
        </figure>
      {% endfor %}
    </aside>
  {% endif %}
</section>
