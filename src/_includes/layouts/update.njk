---
layout: layouts/base.njk
pageClass: page-update-detail
---
{% set hasBodyContent = content | trim %}
{% set displayTags = tags | displayTags %}

<section class="detail-hero shell detail-hero-copy-first detail-hero-centered">
  <div class="detail-hero-copy detail-hero-copy-centered">
    <h1>{{ title }}</h1>
    <div class="detail-meta detail-meta-split">
      <div class="tag-row tag-row-compact">
        {% for tag in displayTags %}
          <span class="tag-chip">{{ tag }}</span>
        {% endfor %}
      </div>
      <span class="detail-date">{{ date | readableDate }}</span>
    </div>
  </div>
</section>

{% if hasBodyContent %}
  <section class="shell detail-layout detail-layout-single detail-layout-update">
    <article class="detail-article">
      <div class="detail-prose" data-prose>
        {{ content | safe }}
      </div>
    </article>
  </section>
{% endif %}
