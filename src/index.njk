---
layout: layouts/base.njk
pageClass: page-home
title: Home
description: Ryan Wheeler's games, art, projects, updates, and tools.
---
{% set featuredProject = collections.projects | featuredProject %}
{% set recentUpdates = collections.updates | limit(8) %}
{% set projectItems = collections.projects %}
{% set tools = collections.tools | limit(4) %}

<section class="home-layout home-layout-wide">
  <aside class="home-side-rail">
    <div class="home-column-panel home-updates-panel">
      <div class="home-section-heading">
        <h2>Updates</h2>
      </div>

      <div class="home-stack-list">
        {% for update in recentUpdates %}
          <a class="update-button home-list-card" href="{{ update.url }}">
            <img src="{{ update.data.thumbnail }}" alt="{{ update.data.title }}">
            <div class="update-button-copy">
              <h3>{{ update.data.title }}</h3>
              <p class="list-card-date">{{ update.date | teaserDate }}</p>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </aside>

  <div class="home-main-column">
    <section class="home-splash">
      <a class="home-splash-link" href="{{ featuredProject.url }}">
        {% managedImage featuredProject.data.heroImage or featuredProject.data.thumbnail, featuredProject.data.title, "home-splash-managed", true %}
      </a>
    </section>

    <section class="home-feature">
      <div class="home-feature-top">
        <h1>{{ featuredProject.data.title }}</h1>
        {% if featuredProject.data.externalLinks and featuredProject.data.externalLinks[0] %}
          <a class="feature-link" href="{{ featuredProject.data.externalLinks[0].url }}" target="_blank" rel="noopener">
            {{ featuredProject.data.externalLinks[0].label }}
          </a>
        {% endif %}
      </div>
      <p>{{ featuredProject.data.summary }}</p>
    </section>

    <section class="home-projects">
      <div class="home-section-heading">
        <h2>Projects</h2>
      </div>

      <div class="home-project-grid">
        {% for project in projectItems %}
          <a class="project-button home-project-card" href="{{ project.url }}">
            {% managedLoop project.data.thumbnail, project.data.title, "home-project-managed" %}
            <div class="project-button-copy">
              <h3>{{ project.data.title }}</h3>
              <p>{{ project.data.dateLabel }}</p>
            </div>
          </a>
        {% endfor %}
      </div>
    </section>
  </div>

  <aside class="home-side-rail home-tools-rail">
    <div class="home-column-panel home-tools-panel">
      <div class="home-section-heading">
        <h2>Tools</h2>
      </div>

      {% if tools.length %}
        <div class="home-stack-list">
          {% for tool in tools %}
            <a class="tool-card home-list-card" href="{{ tool.url }}">
              {% if tool.data.thumbnail %}
                <img src="{{ tool.data.thumbnail }}" alt="{{ tool.data.title }}">
              {% else %}
                <span class="tool-icon-fallback tool-icon-fallback-small" aria-hidden="true">
                  <i class="{{ tool.data.icon or 'fas fa-circle' }}"></i>
                </span>
              {% endif %}
              <div>
                <h3>{{ tool.data.title }}</h3>
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state-card">
          <h3>No public tools yet.</h3>
        </div>
      {% endif %}
    </div>
  </aside>
</section>
